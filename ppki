                    <div>
                        <span class="bg-sky-500 text-white text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 rounded-full">Buku Pengurusan</span>
                        <h3 class="font-extrabold text-lg md:text-xl text-cheerful-text group-hover:text-sky-600 transition-colors mt-2.5 leading-snug card-title">PORTAL BUKU PENGURUSAN</h3>
                        <p class="text-xs text-gray-500 font-semibold mt-1">Manual Operasi & Perancangan Tahunan PPKI</p>
                    </div>
                    <p class="text-xs font-bold text-sky-600 font-friendly group-hover:underline flex items-center uppercase tracking-wide mt-4">
                        Buka Folder Panduan <i class="fas fa-arrow-right ml-1 text-xs group-hover:translate-x-1 transition-transform"></i>
                    </p>
                </div>
                <div class="relative z-10 w-16 h-16 md:w-20 md:h-20 bg-white text-sky-600 rounded-2xl rotate-3 group-hover:rotate-0 transition-all duration-300 shadow-md flex items-center justify-center border-[2.5px] border-sky-500 ml-4 shrink-0">
                    <i class="fas fa-book-bookmark text-3xl md:text-4xl"></i>
                </div>
            </div>

        </div>

        <!-- No Results Message -->
        <div id="noResults" class="hidden text-center py-12">
            <div class="w-16 h-16 bg-gray-100 text-gray-400 rounded-full flex items-center justify-center text-2xl mx-auto mb-3">
                <i class="fas fa-search-minus"></i>
            </div>
            <h3 class="font-bold text-lg text-gray-600">Tiada rekod ditemui</h3>
            <p class="text-sm text-gray-400 mt-1">Sila cuba kata kunci atau pilihan tapisan yang lain.</p>
        </div>
    </main>

    <!-- CUSTOM MODAL DIALOGUE (REPLACING BROWSER ALERT) -->
    <div id="infoModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/40 backdrop-blur-xs hidden transition-all opacity-0 duration-300">
        <div class="bg-white rounded-3xl p-6 md:p-8 max-w-md w-full shadow-2xl border border-gray-100 transform scale-95 transition-transform duration-300">
            <div class="flex items-center gap-4 border-b border-gray-100 pb-4">
                <div id="modalIconBg" class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl shadow-inner">
                    <i id="modalIcon" class="fas fa-info"></i>
                </div>
                <div>
                    <h4 id="modalTitle" class="font-extrabold text-lg md:text-xl text-cheerful-text">Maklumat Tambahan</h4>
                    <p id="modalCategory" class="text-xs font-bold text-gray-400 uppercase tracking-wider">Kategori</p>
                </div>
            </div>
            <div class="py-5">
                <p id="modalDescription" class="text-sm text-gray-600 font-medium leading-relaxed">
                    Sila hubungi pentadbir sekolah jika ada masalah berkaitan data ini.
                </p>
                <!-- Detail Info Box -->
                <div class="mt-4 bg-gray-50/80 rounded-2xl p-4 border border-gray-100 text-xs text-gray-500 space-y-1.5 font-semibold">
                    <div class="flex justify-between">
                        <span>Penyelia:</span>
                        <span class="text-gray-700">Penyelaras PPKI</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Sesi Semakan:</span>
                        <span class="text-gray-700">Tahun 2026</span>
                    </div>
                </div>
            </div>
            <div class="flex gap-3 justify-end pt-2 border-t border-gray-100">
                <button onclick="closeModal()" class="px-5 py-2.5 rounded-xl text-sm font-bold bg-gray-100 hover:bg-gray-200 text-gray-600 transition-colors">Tutup</button>
                <button id="modalActionBtn" class="px-5 py-2.5 rounded-xl text-sm font-bold bg-cheerful-skyDeep hover:bg-sky-700 text-white transition-colors flex items-center gap-1.5">
                    Lawati Pautan <i class="fas fa-external-link-alt text-xs"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="w-full max-w-7xl mx-auto px-4 mt-auto">
        <div class="border-t border-gray-200/50 pt-6 text-center text-xs text-gray-400 font-bold flex flex-col sm:flex-row justify-between items-center gap-3">
            <p>&copy; 2026 Program Pendidikan Khas Integrasi (PPKI) SK Simpang Empat.</p>
            <p class="flex items-center gap-1"><i class="fas fa-heart text-rose-500"></i> Untuk kegunaan pengurusan PPKI</p>
        </div>
    </footer>

    <!-- JAVASCRIPT FUNCTIONS -->
    <script>
        // Update Live clock and date
        function updateClock() {
            const now = new Date();
            
            // Format Time
            const timeOptions = { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
            document.getElementById('liveTime').textContent = now.toLocaleTimeString('ms-MY', timeOptions);
            
            // Format Date
            const dateOptions = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
            document.getElementById('liveDate').textContent = now.toLocaleDateString('ms-MY', dateOptions);
        }
        
        // Initial call and interval setup
        updateClock();
        setInterval(updateClock, 1000);

        // Core open & click state function
        function animateAndOpen(element, url) {
            // Apply visual bounce/ripple effect
            element.classList.add('scale-95', 'opacity-90');
            setTimeout(() => {
                element.classList.remove('scale-95', 'opacity-90');
                
                // If it has active direct URL
                if (url && url !== '#') {
                    window.open(url, '_blank');
                } else {
                    // Open Custom Detailed Modal instead of default browser alert
                    openModal(element);
                }
            }, 180);
        }

        // Custom Modal Logic
        const modal = document.getElementById('infoModal');
        const modalContent = modal.querySelector('div');

        function openModal(btnElement) {
            const title = btnElement.querySelector('.card-title')?.textContent || "MAKLUMAT LANJUT";
            const badge = btnElement.querySelector('span')?.textContent || "Panduan Sistem";
            const borderClasses = Array.from(btnElement.classList).find(c => c.startsWith('border-t-'));
            let colorHex = "text-sky-600";
            let bgHex = "bg-sky-50";

            if (borderClasses) {
                if (borderClasses.includes('rose-500') || borderClasses.includes('rose-400')) {
                    colorHex = "text-rose-600";
                    bgHex = "bg-rose-50";
                } else if (borderClasses.includes('emerald')) {
                    colorHex = "text-emerald-600";
                    bgHex = "bg-emerald-50";
                } else if (borderClasses.includes('amber')) {
                    colorHex = "text-amber-600";
                    bgHex = "bg-amber-50";
                } else if (borderClasses.includes('indigo')) {
                    colorHex = "text-indigo-600";
                    bgHex = "bg-indigo-50";
                } else if (borderClasses.includes('violet')) {
                    colorHex = "text-violet-600";
                    bgHex = "bg-violet-50";
                }
            }

            // Set content to modal dynamically
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalCategory').textContent = badge;
            
            // Set dynamic icon colors
            const iconBg = document.getElementById('modalIconBg');
            iconBg.className = `w-12 h-12 rounded-2xl flex items-center justify-center text-2xl shadow-inner ${bgHex} ${colorHex}`;
            
            // Re-assign main icon inside modal based on trigger
            const sourceIcon = btnElement.querySelector('i');
            const targetIcon = document.getElementById('modalIcon');
            if (sourceIcon) {
                targetIcon.className = sourceIcon.className;
            }

            // Custom specific instructions for system
            let customDesc = "Data ini mengandungi perincian kebajikan, bantuan kewangan, serta bantuan Elaun Murid Khas (EMK). Semua rekod diselaraskan untuk kegunaan PPKI SK Simpang Empat 2026.";
            if (title.includes("KEBAJIKAN")) {
                customDesc = "Portal Bantuan, Pengurusan Rantau Makanan Tambahan (RMT), serta semakan kemasukan bantuan Elaun Murid Khas (EMK) PPKI SKSE.";
                document.getElementById('modalActionBtn').onclick = function() {
                    window.open('https://apdm.moe.gov.my/', '_blank');
                };
            } else {
                document.getElementById('modalActionBtn').onclick = function() {
                    closeModal();
                };
            }
            document.getElementById('modalDescription').textContent = customDesc;

            // Display modal with animation
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 20);
        }

        function closeModal() {
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        // Close on escape key
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });

        // Interactive Filtering (Carian & Kategori)
        let activeTab = 'semua';

        function setTab(category) {
            activeTab = category;
            
            // Update active state of buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.className = "tab-btn bg-white/80 hover:bg-gray-100 text-gray-600 text-xs md:text-sm font-bold font-friendly px-4 py-2 rounded-xl transition-all border border-gray-200";
            });

            // Find current clicked and set high contrast color
            const clickedBtn = Array.from(document.querySelectorAll('.tab-btn')).find(b => b.textContent.toLowerCase().includes(category) || (category === 'semua' && b.textContent === 'Semua'));
            if (clickedBtn) {
                clickedBtn.className = "tab-btn active bg-cheerful-skyDeep text-white text-xs md:text-sm font-bold font-friendly px-4 py-2 rounded-xl transition-all shadow-sm";
            }

            filterCards();
        }

        function filterCards() {
            const searchValue = document.getElementById('searchInput').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.nav-card');
            let hasVisibleCard = false;

            cards.forEach(card => {
                const title = card.querySelector('.card-title')?.textContent.toLowerCase() || "";
                const categories = card.getAttribute('data-category') || "";
                
                const matchesSearch = title.includes(searchValue);
                const matchesCategory = (activeTab === 'semua') || categories.includes(activeTab);

                if (matchesSearch && matchesCategory) {
                    card.classList.remove('hidden');
                    hasVisibleCard = true;
                } else {
                    card.classList.add('hidden');
                }
            });

            // Show 'No Results' notice if everything is filtered out
            const noResults = document.getElementById('noResults');
            if (hasVisibleCard) {
                noResults.classList.add('hidden');
            } else {
                noResults.classList.remove('hidden');
            }
        }
    </script>
</body>
</html>
